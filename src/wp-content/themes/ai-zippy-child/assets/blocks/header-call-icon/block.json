{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/header-call-icon",
  "version": "1.0.0",
  "title": "Header Call Us Icon",
  "category": "ai-zippy",
  "icon": "phone",
  "description": "Single Call Us icon link for the site header.",
  "keywords": [
    "header",
    "call",
    "phone",
    "icon"
  ],
  "supports": {
    "html": false,
    "reusable": true
  },
  "attributes": {
    "phoneNumber": {
      "type": "string",
      "default": "+6565134757"
    },
    "ariaLabel": {
      "type": "string",
      "default": "Call Us"
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}